# World Labs Platform API Key (from platform.worldlabs.ai, NOT the Marble web app)
WLT_API_KEY=your_world_labs_platform_key_here

# Google Cloud Project ID (for Vertex AI / Gemini 2.5 Pro)
GOOGLE_CLOUD_PROJECT=your_gcp_project_id

# Google Cloud Location (default us-central1)
GOOGLE_CLOUD_LOCATION=us-central1

GOOGLE_GENAI_USE_VERTEXAI=true